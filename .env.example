# .env.example
# Rename this file to .env and fill in the required keys

# Telegram Bot Token (Optional, for notifications)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# OpenDart API Key (Optional)
OPENDART_API_KEY=your_opendart_api_key_here

# Supabase URL/Key (Optional, for DB storage)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key_here

# OpenAI API Key (Optional, for advanced news summarization)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MARKET_INTEL_MODEL=gemini-2.5-pro
AG_MARKET_INTEL_GEMINI_PRIMARY_MODEL=gemini-2.5-flash
AG_MARKET_INTEL_GEMINI_SECONDARY_MODEL=gemini-2.5-pro
AG_MARKET_INTEL_GEMINI_TIMEOUT_SEC=25
AG_MARKET_INTEL_LEADER_COUNT=6
AG_MARKET_INTEL_LEADER_COUNT_KOSPI=6
AG_MARKET_INTEL_LEADER_COUNT_KOSDAQ=8
AG_MARKET_INTEL_LEADER_COUNT_KR=8
AG_MARKET_INTEL_LEADER_COUNT_OPEN_BONUS=2

# --- Multi-agent runtime toggles ---
# Scan profile: prod|dev
AG_SCAN_PROFILE=prod

# Daily summary auto emit from non-ui pipeline: 1|0
AG_EMIT_DAILY_SUMMARY=1

# Outcome updater safety:
# expire pending rows without DB lookup check: 1|0 (recommended: 0)
AG_ALLOW_EXPIRE_WITHOUT_DB=0

# Postmortem stale/expiry thresholds
AG_POSTMORTEM_EXPIRED_MIN=5
AG_POSTMORTEM_EXPIRED_RATE_MIN=0.25
AG_POSTMORTEM_FALLBACK_EXPIRED_MIN=2

# Stale fallback alert hook
AG_STALE_FALLBACK_ALERT_ENABLE=1
AG_STALE_FALLBACK_ALERT_MIN=3
AG_STALE_FALLBACK_ALERT_LIMIT_RUNS=200
AG_STALE_FALLBACK_ALERT_WEBHOOK_URL=
AG_STALE_FALLBACK_ALERT_DRY_RUN=1

# Daily ops script behavior
DAILY_OPS_DRY_RUN=1
DAILY_OPS_RESOLVE_ALL=0
DAILY_OPS_REFRESH_SIGNAL_PERFORMANCE=0
DAILY_OPS_MARKET=NASDAQ
DAILY_OPS_LIMIT_RUNS=200

# Scanner precision gate:
# keep weak T3 / low-ML-support setups out of the final scan list
AG_ENABLE_PRECISION_GATE=1
AG_GREEN_MIN_CONVICTION=57
AG_YELLOW_MIN_CONVICTION=62
AG_RED_MIN_CONVICTION=70
AG_KOSDAQ_RED_MIN_CONVICTION=64
AG_KOSDAQ_RED_ALPHA_RELAX_FLOOR=45
AG_KOSDAQ_BEAR_DOWN_MIN_ALPHA=45
AG_SCAN_MIN_PROB=52
AG_SCAN_MIN_CLEAN_PROB=50

# Liquidity filters:
# separate KOSPI/KOSDAQ turnover floors so KOSDAQ is not forced into KOSPI liquidity rules
AG_US_MIN_PRICE=1
AG_US_MIN_TURNOVER=1000000
AG_KR_MIN_PRICE=1000
AG_KOSPI_MIN_TURNOVER=10000000000
AG_KOSDAQ_MIN_TURNOVER=7000000000
AG_INTRADAY_KOSPI_MIN_TURNOVER=700000000
AG_INTRADAY_KOSDAQ_MIN_TURNOVER=300000000
AG_INTRADAY_KR_MIN_VOLUME=20000
AG_INTRADAY_US_MIN_TURNOVER=1500000
AG_INTRADAY_US_MIN_VOLUME=40000
AG_INTRADAY_AMEX_MIN_TURNOVER=400000
AG_INTRADAY_AMEX_MIN_VOLUME=20000
AG_AMEX_MOONSHOT_MIN_PRICE=0.7
AG_AMEX_MOONSHOT_PREFERRED_MAX_PRICE=7.0
AG_AMEX_MOONSHOT_MAX_PRICE=25
AG_AMEX_MOONSHOT_MIN_ALPHA=28
AG_AMEX_MOONSHOT_MIN_ALPHA_DOWN=40
AG_AMEX_MOONSHOT_MIN_VOLUME_RATIO=1.8
AG_AMEX_MOONSHOT_MIN_DAY_CHANGE=4.0
AG_AMEX_MOONSHOT_MIN_RANGE_PCT=6.0
AG_AMEX_MOONSHOT_MIN_RS=-12.0
AG_AMEX_MOONSHOT_BREAKOUT_LOOKBACK=20
AG_AMEX_MOONSHOT_MAX_CLOSE_TO_HIGH_PCT=2.5
AG_AMEX_MOONSHOT_SIGNAL_LOOKBACK=20
AG_AMEX_MOONSHOT_SIGNAL_MIN_HITS=0
AG_AMEX_MOONSHOT_MIN_SCORE=62
AG_AMEX_MOONSHOT_POLICY_OVERRIDE_SCORE=78
AG_AMEX_MOONSHOT_SUB7_BONUS=10.0
AG_AMEX_MOONSHOT_SUB7_BREAKOUT_BONUS=8.0
AG_AMEX_RED_MIN_CONVICTION=56
AG_AMEX_SCAN_MIN_PROB=42
AG_AMEX_SCAN_MIN_CLEAN_PROB=38
AG_LEARNING_NIGHTLY_MIN_NEW_RESOLVED=20
AG_LEARNING_WEEKLY_MIN_TOTAL_RESOLVED=50
AG_LEARNING_WEEKLY_MIN_NEW_RESOLVED=10
AG_KOSPI_UNIVERSE_MIN_AMOUNT=12000000000
AG_KOSDAQ_UNIVERSE_MIN_AMOUNT=5000000000
AG_KRX_ENFORCE_UNIVERSE_MIN_AMOUNT=0

# KRX universe hygiene:
# keep the full KR universe by default; opt in to stricter prefiltering only if needed
AG_KRX_MIN_LISTING_DAYS=0
AG_KRX_EXCLUDE_SPACS=1
AG_KRX_EXCLUDE_NON_NUMERIC_CODES=1
AG_KR_STOCK_THEME_MASTER_PATH=/Users/dongdong/Downloads/kospi_kosdaq_allstocks_structured.jsonl

# --- Discord remote control integration ---
# Create a Discord application + bot in Discord Developer Portal, then fill these.
# Keep DISCORD_DRY_RUN=1 until the doctor passes and command registration is intentional.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_RESULT_CHANNEL_ID=
DISCORD_ALLOWED_USER_IDS=
DISCORD_ALLOWED_ROLE_IDS=
DISCORD_COMMAND_SCOPE=guild
DISCORD_DRY_RUN=1
DISCORD_ENABLE_SCAN_EXECUTION=0
DISCORD_WEB_BASE_URL=http://localhost:8501
